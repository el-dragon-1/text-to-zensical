# Team runtime template for docker-compose.release.yml
# Copy this file to .env and update image coordinates + SECRET_KEY.

# Published image coordinates
TEXT_TO_ZENSICAL_IMAGE=ghcr.io/el-dragon-1/text-to-zensical
TEXT_TO_ZENSICAL_TAG=latest

# Runtime settings
PORT=10253
OUTPUT_ROOT=/data/exports

# Required: replace with a strong random value
# Example: openssl rand -hex 32
SECRET_KEY=replace-with-a-long-random-secret
